# Server encryption key for API key storage (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-char-hex-key-here

# Server port (default: 3001)
PORT=3001

# Optional HTTP Basic Auth for the admin dashboard and /api/* admin routes.
# Set BOTH to enable. Local dev can leave them unset.
# ADMIN_USER=admin
# ADMIN_PASSWORD=replace-me-with-a-strong-password

# Optional: provider keys to auto-seed on every startup. Useful on hosts
# with ephemeral disks (e.g. Render free tier) where the SQLite database
# is wiped on each redeploy. Keys you add manually via the dashboard are
# preserved alongside these (different label).
# GOOGLE_API_KEY=AIzaSy...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-v1-...
# CEREBRAS_API_KEY=
# SAMBANOVA_API_KEY=
# NVIDIA_API_KEY=
# MISTRAL_API_KEY=
# GITHUB_API_KEY=
# HUGGINGFACE_API_KEY=
# COHERE_API_KEY=
# CLOUDFLARE_API_KEY=
